{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --use-openssl-ca --env-file ../../.env --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@qdrant/js-client-rest": "^1.18.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "axios": "^1.17.0",
    "cheerio": "^1.2.0",
    "chrome-remote-interface": "^0.34.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "fastmcp": "^4.3.2",
    "firecrawl": "^4.30.1",
    "langfuse": "^3.38.20",
    "pdf-parse": "^2.4.5",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "puppeteer": "^25.3.0",
    "ws": "^8.21.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0"
  }
