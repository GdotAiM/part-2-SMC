# ──────────────────────────────────────────────────────────────────────────────
# SMC Pulse Predict — AMD Developer Cloud Environment
# ──────────────────────────────────────────────────────────────────────────────
# Copy to .env and edit before first launch:  cp .env.amd .env
# ──────────────────────────────────────────────────────────────────────────────

# ── LLM / vLLM ────────────────────────────────────────────────────────────────
# Model to serve on the MI300X (any HuggingFace model with vLLM ROCm support).
# Gemma 4 26B A4B is the default — a strong MoE model for trading analysis.
# Also available: Gemma 4 12B, 31B (see README sizing table).
LLM_MODEL=google/gemma-4-26B-A4B-it

# Tool-call / reasoning parser for vLLM.  Set to "gemma4" for all Gemma 4
# family models.  For non-Gemma models, change this to the appropriate parser
# (e.g. "hermes", "mistral", "llama3_json") or leave empty to disable.
# See README for the full list of supported parser names.
LLM_TOOL_PARSER=gemma4

# vLLM tuning (leave defaults unless you know what you're doing)
VLLM_PORT=8000
VLLM_MAX_MODEL_LEN=8192
VLLM_GPU_MEM_UTIL=0.92
VLLM_TP_SIZE=1
VLLM_DTYPE=auto

# Required: ROCm GPU target for MI300X (gfx942).  Do not change.
HSA_OVERRIDE_GFX_VERSION=9.4.2

# ── API Server ────────────────────────────────────────────────────────────────
API_PORT=3001
MCP_PORT=3002

# CORS allowed origins.  "*" = any origin (default).  For production, set to a
# comma-separated list of allowed origins, e.g. "https://my-frontend.com".
CORS_ORIGINS=*

# ── Optional external services ────────────────────────────────────────────────
# Fill these in if you want live crypto/forex data via Binance & Finnhub.
# The API server will start without them, but market data will be empty.
BINANCE_API_KEY=
FINNHUB_API_KEY=

# ── Broker / Execution ────────────────────────────────────────────────────────
# Alpaca Paper Trading API credentials (optional).  Set both to enable live
# paper-trading order execution through AlpacaAdapter.  If left empty, the
# server falls back to MockBrokerAdapter (file-based, no real orders).
# Get your keys at https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=

# Database (PostgreSQL connection string).  Leave empty to run without
# persistence — the server will work but won't store user state.
DATABASE_URL=
