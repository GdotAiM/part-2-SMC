# ──────────────────────────────────────────────────────────────────────────────
# SMC Pulse Predict — Local / Intel CPU Environment
# ──────────────────────────────────────────────────────────────────────────────
# Copy to .env and edit before first launch:  cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# ── LLM Provider (required) ───────────────────────────────────────────────────
# Fireworks AI hosts DeepSeek V4 Pro — fast, cheap, no GPU needed.
# Get a free API key at https://fireworks.ai/api-keys
# Provider options: fireworks (default) | openai | custom | amd (GPU only)
LLM_PROVIDER=fireworks
FIREWORKS_API_KEY=

# Override the default model (optional).  DeepSeek V4 Pro is the default.
# LLM_MODEL=accounts/fireworks/models/deepseek-v4-pro

# For OpenAI instead of Fireworks:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# ── Server Ports ──────────────────────────────────────────────────────────────
API_PORT=3001
MCP_PORT=3002
FRONTEND_PORT=3000
CORS_ORIGINS=*

# ── Market Data (optional) ────────────────────────────────────────────────────
# Crypto uses Binance public WebSocket without a key.  Forex uses Finnhub if a
# key is present, otherwise falls back to Yahoo polling (15s intervals).
BINANCE_API_KEY=
FINNHUB_API_KEY=

# ── Broker / Execution (optional) ─────────────────────────────────────────────
# Alpaca Paper Trading — set both to enable live paper-trading.  If empty, the
# server uses a file-based MockBroker (writes to data/mock_broker/).
# Get keys at https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
