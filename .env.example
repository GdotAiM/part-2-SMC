# SMC Liquidity Hunter — environment variables
#
# Copy this file to `.env` and fill in the values you need. Only PORT is
# required to boot the API server; everything else is optional and the app
# degrades gracefully:
#   - No DATABASE_URL        → Analytics page shows empty states (no crash)
#   - No LLM key / no vLLM   → AI endpoints return "AI not configured"
#   - No ALPACA_*            → broker falls back to the file-based MockBroker
#   - No BINANCE/FINNHUB key → crypto uses Binance public WS; forex uses
#                              Yahoo polling (15s)
#
# For the AMD Developer Cloud deployment (vLLM on MI300X), use the richer
# template at deploy/amd-developer-cloud/.env.amd instead — it also covers
# the vLLM container (VLLM_*, HF_TOKEN, HSA_OVERRIDE_GFX_VERSION).

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001                # API + SSE port
MCP_PORT=3002            # FastMCP server port (external AI agents)
CORS_ORIGINS=*           # comma-separated allowlist, or "*" for any origin
LOG_LEVEL=info           # pino log level

# ── Database (optional) ──────────────────────────────────────────────────────
# Postgres connection string. Required only for the trade ledger + performance
# matrix (the /api/ledger and /api/performance-matrix routes). Without it,
# those routes return empty data and the Analytics page renders empty states.
# DATABASE_URL=postgresql://smc:smc-liquidity-hunter@localhost:5432/smc_liquidity

# ── LLM provider ─────────────────────────────────────────────────────────────
# One provider is chosen via LLM_PROVIDER.
#
#   fireworks → Fireworks AI hosted API (default — no GPU needed)
#   openai    → OpenAI API (needs OPENAI_API_KEY)
#   custom    → any OpenAI-compatible endpoint (set LLM_BASE_URL + LLM_API_KEY)
#   amd       → self-hosted vLLM on AMD GPU (for MI300X deployment)
LLM_PROVIDER=fireworks
# FIREWORKS_API_KEY=
# LLM_MODEL=accounts/fireworks/models/deepseek-v4-pro
#
# For AMD GPU deployment, use deploy/amd-developer-cloud/.env.amd instead.
# For local Docker deployment, use deploy/local/.env.example instead.

# ── Market data (all optional) ───────────────────────────────────────────────
# Crypto works over Binance's public WebSocket without a key. Forex uses
# Finnhub if a key is present, otherwise falls back to Yahoo polling.
# BINANCE_API_KEY=
# FINNHUB_API_KEY=

# ── Broker execution (optional) ──────────────────────────────────────────────
# If both are set, the Alpaca paper-trading adapter is used. Otherwise the
# file-based MockBroker is used (writes to data/mock_broker/).
# ALPACA_API_KEY_ID=
# ALPACA_API_SECRET_KEY=
