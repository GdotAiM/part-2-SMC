{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": [
      "artifacts/api-server/**",
      "lib/**"
    ]
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ALWAYS",
    "healthcheckPath": "/api/healthz",
    "healthcheckTimeout": 5
  },
  "services": [
    {
      "name": "api-server",
      "buildCommand": null,
      "runCommand": "node artifacts/api-server/dist/index.mjs",
      "variables": {
        "NODE_ENV": "production",
        "PORT": "3001",
        "MCP_PORT": "3002",
        "LLM_PROVIDER": "fireworks",
        "CORS_ORIGINS": "*"
      },
      "volumes": []
    }
  ]
}
